<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Accounting Jumble</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: Georgia, serif;
    background: #f4f4f4;
    padding: 20px;
  }

  .puzzle-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 20px;
    border: 3px solid #222;
    background: white;
  }

  .puzzle-title {
    text-align: center;
    font-size: 28px;
    font-weight: 900;
    letter-spacing: 4px;
    border-bottom: 3px solid #222;
    padding-bottom: 10px;
    margin-bottom: 6px;
    font-family: 'Arial Black', Arial, sans-serif;
    color: #111;
  }

  .puzzle-subtitle {
    text-align: center;
    font-size: 12px;
    letter-spacing: 2px;
    margin-bottom: 14px;
    color: #555;
    font-family: Arial, sans-serif;
    text-transform: uppercase;
  }

  /* ── Cartoon ── */
  .cartoon-box {
    border: 2px solid #222;
    margin-bottom: 16px;
    padding: 10px;
    background: #fffdf5;
  }
  .cartoon-svg { display: block; width: 100%; }
  .caption-box {
    border-top: 2px solid #222;
    padding-top: 8px;
    margin-top: 8px;
    font-size: 14px;
    font-style: italic;
    font-family: Arial, sans-serif;
    color: #222;
    text-align: center;
    line-height: 1.5;
  }

  /* ── Instructions ── */
  .instructions {
    font-family: Arial, sans-serif;
    font-size: 13px;
    color: #444;
    margin-bottom: 12px;
    text-align: center;
    font-style: italic;
  }

  /* ── Word puzzles ── */
  .words-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-bottom: 16px;
  }

  .word-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .word-label {
    font-size: 10px;
    letter-spacing: 1px;
    color: #666;
    font-family: Arial, sans-serif;
    text-transform: uppercase;
  }

  /* Scrambled letter tiles */
  .scrambled-row {
    display: flex;
    gap: 3px;
  }

  .scram-tile {
    width: 30px;
    height: 30px;
    border: 2px solid #222;
    background: #fffbe6;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 17px;
    font-weight: 900;
    font-family: 'Arial Black', Arial, sans-serif;
    color: #111;
    cursor: pointer;
    user-select: none;
    transition: background 0.15s;
  }
  .scram-tile:hover { background: #ffe98a; }
  .scram-tile.used {
    background: #ddd;
    color: #aaa;
    cursor: default;
  }

  /* Answer input row */
  .answer-row {
    display: flex;
    gap: 3px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .ans-cell {
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 17px;
    font-weight: 900;
    font-family: 'Arial Black', Arial, sans-serif;
    color: #111;
    cursor: pointer;
    position: relative;
  }

  /* Plain underline cell */
  .ans-cell.plain {
    border-bottom: 2.5px solid #333;
  }

  /* Circled cell */
  .ans-cell.circled {
    border: 2.5px solid #111;
    border-radius: 50%;
  }

  .ans-cell.filled { color: #1a5fa8; }
  .ans-cell.filled:hover { color: #c0392b; }

  /* ── Final answer section ── */
  .answer-section {
    border: 2px solid #222;
    padding: 14px;
    background: #fffdf5;
  }

  .answer-section-title {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-family: Arial, sans-serif;
    color: #555;
    margin-bottom: 6px;
    text-align: center;
  }

  .answer-clue {
    font-size: 13px;
    font-style: italic;
    font-family: Arial, sans-serif;
    color: #222;
    text-align: center;
    margin-bottom: 12px;
    line-height: 1.5;
  }

  .final-answer-area {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }

  .final-word {
    display: flex;
    gap: 3px;
  }

  .final-cell {
    width: 28px;
    height: 28px;
    border: 2px solid #111;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    font-weight: 900;
    font-family: 'Arial Black', Arial, sans-serif;
    color: #1a5fa8;
    background: #eef4fc;
    cursor: pointer;
  }
  .final-cell:hover { background: #fdecea; color: #c0392b; }
  .final-cell.empty { background: white; color: transparent; }

  /* ── Buttons ── */
  .btn-row {
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  button {
    padding: 7px 20px;
    font-size: 12px;
    letter-spacing: 1px;
    font-family: Arial, sans-serif;
    font-weight: 700;
    text-transform: uppercase;
    background: white;
    border: 2px solid #222;
    cursor: pointer;
    border-radius: 2px;
  }
  button:hover { background: #f0f0f0; }
  button.primary { background: #2c3e50; color: white; border-color: #2c3e50; }
  button.primary:hover { background: #1a252f; }

  /* ── Feedback ── */
  .feedback {
    text-align: center;
    margin-top: 10px;
    font-family: Arial, sans-serif;
    font-size: 14px;
    font-weight: 700;
    min-height: 22px;
  }
  .feedback.correct { color: #27ae60; }
  .feedback.incorrect { color: #c0392b; }
  .feedback.reveal { color: #2c3e50; letter-spacing: 2px; font-size: 18px; }

  /* ── Score ── */
  .score-area {
    text-align: center;
    font-family: Arial, sans-serif;
    font-size: 13px;
    color: #555;
    margin-bottom: 10px;
  }

  .word-status {
    font-size: 11px;
    font-family: Arial, sans-serif;
    color: #888;
    margin-top: 2px;
  }
  .word-status.solved { color: #27ae60; font-weight: 700; }

  /* Responsive */
  @media (max-width: 500px) {
    .words-grid { grid-template-columns: 1fr; }
    .scram-tile, .ans-cell { width: 26px; height: 26px; font-size: 14px; }
    .puzzle-title { font-size: 20px; letter-spacing: 2px; }
  }
</style>
</head>
