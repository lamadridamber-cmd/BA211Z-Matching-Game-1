<script>
// ── Puzzle data ──
const WORDS = [
  { word: "ACCOUNTS",  scrambled: "OCSTCANU", circled: [2,6]   },
  { word: "REVENUE",   scrambled: "UENREVE",  circled: [1,2,5] },
  { word: "BALANCE",   scrambled: "CLENABA",  circled: [3,6]   },
  { word: "PREPAID",   scrambled: "DRPIAPE",  circled: [1,4,6] },
  { word: "AMORTIZE",  scrambled: "ZETAMIRO", circled: [2,5]   },
  { word: "CASH",      scrambled: "HACS",     circled: [2,4]   },
  { word: "BUILDINGS", scrambled: "GUILDSNIB",circled: [3,8]   },
];

// Final answer words and which positions are in the answer blanks
const FINAL_WORDS = ["MATCHING", "PRINCIPLE"];
const FINAL_ANSWER = "MATCHINGPRINCIPLE";

// State per word: which scrambled indices have been used, and what's in each answer slot
const state = WORDS.map(pw => ({
  usedScram: new Array(pw.scrambled.length).fill(false),
  answerSlots: new Array(pw.word.length).fill(null), // null or {letter, scramIdx}
  solved: false
}));

// Final answer state: array of letters placed (null = empty)
const finalState = {
  slots: new Array(FINAL_ANSWER.length).fill(null)
};

let solvedCount = 0;

// Build the circled letters pool in order (word by word, circled position order)
// Returns array of {letter, wordIdx, slotIdx}
function getCircledPool() {
  const pool = [];
  WORDS.forEach((pw, wi) => {
    pw.circled.forEach(pos => {
      const slotIdx = pos - 1;
      pool.push({ letter: pw.word[slotIdx], wordIdx: wi, slotIdx });
    });
  });
  return pool;
}

// ── Render word puzzles ──
function renderAll() {
  const grid = document.getElementById('wordsGrid');
  grid.innerHTML = '';
  WORDS.forEach((pw, wi) => renderWord(pw, wi, grid));
  renderFinalAnswer();
  updateScore();
}

function renderWord(pw, wi, grid) {
  const section = document.createElement('div');
  section.className = 'word-section';
  section.id = `word-section-${wi}`;

  const label = document.createElement('div');
  label.className = 'word-label';
  label.textContent = 'Unscramble';
  section.appendChild(label);

  // Scrambled row
  const scramRow = document.createElement('div');
  scramRow.className = 'scrambled-row';
  pw.scrambled.split('').forEach((ch, si) => {
    const tile = document.createElement('div');
    tile.className = 'scram-tile' + (state[wi].usedScram[si] ? ' used' : '');
    tile.textContent = ch;
    tile.dataset.wi = wi;
    tile.dataset.si = si;
    if (!state[wi].usedScram[si] && !state[wi].solved) {
      tile.addEventListener('click', onScramClick);
    }
    scramRow.appendChild(tile);
  });
  section.appendChild(scramRow);

  // Answer row
  const ansRow = document.createElement('div');
  ansRow.className = 'answer-row';
  pw.word.split('').forEach((_, ai) => {
    const pos = ai + 1;
    const isCircled = pw.circled.includes(pos);
    const cell = document.createElement('div');
    cell.className = 'ans-cell ' + (isCircled ? 'circled' : 'plain');
    cell.dataset.wi = wi;
    cell.dataset.ai = ai;
    const filled = state[wi].answerSlots[ai];
    if (filled) {
      cell.textContent = filled.letter;
      cell.classList.add('filled');
      if (!state[wi].solved) cell.addEventListener('click', onAnsClick);
    }
    ansRow.appendChild(cell);
  });
  section.appendChild(ansRow);

  // Status
  const status = document.createElement('div');
  status.className = 'word-status' + (state[wi].solved ? ' solved' : '');
  status.id = `word-status-${wi}`;
  status.textContent = state[wi].solved ? '✓ Correct!' : '';
  section.appendChild(status);

  grid.appendChild(section);
}

function onScramClick(e) {
  const wi = +e.target.dataset.wi;
  const si = +e.target.dataset.si;
  if (state[wi].usedScram[si] || state[wi].solved) return;
  const letter = WORDS[wi].scrambled[si];
  // Find first empty answer slot
  const emptyIdx = state[wi].answerSlots.indexOf(null);
  if (emptyIdx === -1) return;
  state[wi].answerSlots[emptyIdx] = { letter, scramIdx: si };
  state[wi].usedScram[si] = true;
  // Check if word is complete
  if (!state[wi].answerSlots.includes(null)) {
    checkWordAnswer(wi);
  }
  refreshWord(wi);
}

function onAnsClick(e) {
  const wi = +e.target.dataset.wi;
  const ai = +e.target.dataset.ai;
  if (state[wi].solved) return;
  const filled = state[wi].answerSlots[ai];
  if (!filled) return;
  state[wi].usedScram[filled.scramIdx] = false;
  state[wi].answerSlots[ai] = null;
  refreshWord(wi);
}

function checkWordAnswer(wi) {
  const answer = state[wi].answerSlots.map(s => s ? s.letter : '').join('');
  if (answer === WORDS[wi].word) {
    state[wi].solved = true;
    solvedCount++;
    updateScore();
    // Push circled letters into final answer
    pushCircledToFinal(wi);
    refreshFinalAnswer();
  }
}

function pushCircledToFinal(wi) {
  // Determine which slot in finalState these circled letters belong to
  // by counting how many circled letters came before this word
  let offset = 0;
  for (let i = 0; i < wi; i++) {
    offset += WORDS[i].circled.length;
  }
  WORDS[wi].circled.forEach((pos, ci) => {
    const letter = WORDS[wi].word[pos - 1];
    finalState.slots[offset + ci] = letter;
  });
}

function refreshWord(wi) {
  const grid = document.getElementById('wordsGrid');
  const existing = document.getElementById(`word-section-${wi}`);
  if (existing) existing.remove();
  // Re-insert at correct position
  const sections = grid.querySelectorAll('.word-section');
  const refNode = sections[wi] || null;
  const tempGrid = document.createElement('div');
  renderWord(WORDS[wi], wi, tempGrid);
  const newSection = tempGrid.firstChild;
  newSection.id = `word-section-${wi}`;
  grid.insertBefore(newSection, refNode || null);
  if (refNode) grid.removeChild(refNode);
  updateScore();
}

function updateScore() {
  document.getElementById('solvedCount').textContent = solvedCount;
}

// ── Final answer ──
function renderFinalAnswer() {
  const area = document.getElementById('finalAnswerArea');
  area.innerHTML = '';
  let globalIdx = 0;
  FINAL_WORDS.forEach((w, wi) => {
    if (wi > 0) {
      const spacer = document.createElement('div');
      spacer.style.width = '14px';
      area.appendChild(spacer);
    }
    const wordDiv = document.createElement('div');
    wordDiv.className = 'final-word';
    w.split('').forEach((_, li) => {
      const cell = document.createElement('div');
      cell.className = 'final-cell' + (finalState.slots[globalIdx] ? '' : ' empty');
      cell.dataset.idx = globalIdx;
      cell.textContent = finalState.slots[globalIdx] || '';
      if (finalState.slots[globalIdx]) {
        cell.addEventListener('click', onFinalCellClick);
      }
      wordDiv.appendChild(cell);
      globalIdx++;
    });
    area.appendChild(wordDiv);
  });
}

function refreshFinalAnswer() {
  renderFinalAnswer();
  document.getElementById('finalFeedback').textContent = '';
  document.getElementById('finalFeedback').className = 'feedback';
}

function onFinalCellClick(e) {
  const idx = +e.target.dataset.idx;
  finalState.slots[idx] = null;
  refreshFinalAnswer();
}

function checkFinalAnswer() {
  const answer = finalState.slots.map(s => s || '').join('');
  const fb = document.getElementById('finalFeedback');
  if (answer.length < FINAL_ANSWER.length) {
    fb.textContent = 'Keep going — not all letters are placed yet!';
    fb.className = 'feedback incorrect';
    return;
  }
  if (answer === FINAL_ANSWER) {
    fb.textContent = '🎉 Correct! The Matching Principle!';
    fb.className = 'feedback correct';
  } else {
    fb.textContent = 'Not quite — try rearranging the circled letters!';
    fb.className = 'feedback incorrect';
  }
}

function resetFinalAnswer() {
  // Only clear manually placed letters; keep auto-pushed ones from solved words
  // For simplicity, clear all and re-push from solved words
  finalState.slots = new Array(FINAL_ANSWER.length).fill(null);
  WORDS.forEach((pw, wi) => {
    if (state[wi].solved) pushCircledToFinal(wi);
  });
  refreshFinalAnswer();
}

function revealAll() {
  // Solve all words
  WORDS.forEach((pw, wi) => {
    if (!state[wi].solved) {
      // Fill answer slots with correct letters
      pw.word.split('').forEach((ch, ai) => {
        // Find this letter in scrambled
        const si = pw.scrambled.split('').findIndex((sc, idx) => sc === ch && !state[wi].usedScram[idx]);
        if (si !== -1) {
          state[wi].answerSlots[ai] = { letter: ch, scramIdx: si };
          state[wi].usedScram[si] = true;
        }
      });
      state[wi].solved = true;
      solvedCount++;
      pushCircledToFinal(wi);
    }
  });
  // Solve final answer
  FINAL_ANSWER.split('').forEach((ch, i) => { finalState.slots[i] = ch; });
  renderAll();
  renderFinalAnswer();
  const fb = document.getElementById('finalFeedback');
  fb.textContent = 'MATCHING PRINCIPLE';
  fb.className = 'feedback reveal';
}

// ── Init ──
renderAll();
</script>
